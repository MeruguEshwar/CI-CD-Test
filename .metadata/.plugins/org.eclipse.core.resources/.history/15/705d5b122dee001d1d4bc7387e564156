public class CaptchaUtil {

	// captcha class object
	public static Captcha createcaptcha(int height, int width) {

		Captcha cap = new Captcha.Builder(width, height).addBackground(new GradiatedBackgroundProducer())
				.addNoise(new StraightLineNoiseProducer()).addText(new FiveLetterFirstNameTextProducer()).build();
		return cap;
	}

